# NarrativeFlow Configuration

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./narrative_flow/data/narrative_flow.db

# Collection Intervals (seconds)
CRYPTOPANIC_INTERVAL=300      # 5 minutes
REDDIT_INTERVAL=600           # 10 minutes
RSS_INTERVAL=900              # 15 minutes
DEFI_LLAMA_INTERVAL=1800      # 30 minutes
COINGECKO_INTERVAL=600        # 10 minutes
BINANCE_INTERVAL=60           # 1 minute

# Optional API Keys

# CryptoPanic (optional for free tier)
# CRYPTOPANIC_API_KEY=your_key_here

# Reddit API (optional, uses read-only mode without)
# REDDIT_CLIENT_ID=your_client_id
# REDDIT_CLIENT_SECRET=your_client_secret
# REDDIT_USER_AGENT=NarrativeFlow/1.0

# CoinGecko (optional for free tier)
# COINGECKO_API_KEY=your_key_here

# Telegram Bot Configuration
# Get bot token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get your chat ID from @userinfobot on Telegram
# TELEGRAM_CHAT_ID=your_chat_id_here

# Daily briefing time (24-hour format)
TELEGRAM_DAILY_BRIEFING_HOUR=9
TELEGRAM_DAILY_BRIEFING_MINUTE=0

# Alert Settings
ALERT_MAX_PER_NARRATIVE_PER_HOUR=1
ALERT_CRITICAL_BYPASS_LIMIT=true

# Redis Configuration (for rate limiting)
REDIS_URL=redis://localhost:6379/0